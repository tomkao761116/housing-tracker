needs_geo = total - has_coords
needs_poi = has_coords - has_poi if has_coords > has_poi else 0

print(f"總筆數: {total}")
print(f"已有座標: {has_coords}")
print(f"需 Geocoding: {needs_geo}")
print(f"有座標但缺少 POI: {needs_poi}\n")


# ============================================
# Step 2: 批次 Geocoding（差異更新）
# ============================================
if POI_ONLY or needs_geo == 0:
    print(f"Step 2: Geocoding — {'--poi-only 模式跳過' if POI_ONLY else '全部已完成，跳過'}\n")
else:
    print("=" * 60)
    print(f"Step 2: 批次 Geocoding（{needs_geo} 筆需處理）")
    print("=" * 60)

    cur.execute("""
        SELECT t.id, t.address 
        FROM trades t 
        WHERE t.lat IS NULL OR t.lon IS NULL
        ORDER BY t.trade_date DESC NULLS LAST
    """)
    no_coords = cur.fetchall()

    geo_success = 0
    geo_failed = 0

    for i, (tid, addr) in enumerate(no_coords):
        print(f"[{i+1}/{len(no_coords)}] Trade #{tid}: {addr}", end=" → ")
        url = f"https://nominatim.openstreetmap.org/search?format=json&q={urllib.parse.quote(addr)}&limit=1"
        try:
            req = urllib.request.Request(url, headers={"User-Agent": "HousingTracker/1.0"})
            with urllib.request.urlopen(req, timeout=10) as resp:
                data = json.loads(resp.read().decode("utf-8"))
                if data:
                    lat = float(data[0]["lat"])
                    lon = float(data[0]["lon"])
                    cur.execute(
                        "UPDATE trades SET lat = %s, lon = %s WHERE id = %s",
                        (lat, lon, tid)
                    )
                    geo_success += 1
                    print(f"✓ ({lat:.4f}, {lon:.4f})")
                else:
                    geo_failed += 1
                    print("✗ 找不到地址")
        except Exception as e:
            geo_failed += 1
            print(f"✗ {e}")
        time.sleep(1.0)

    print(f"\nGeocoding 完成: 成功 {geo_success} 筆, 失敗 {geo_failed} 筆\n")


