import math
import urllib.request
import urllib.parse
import psycopg2

DB_URL = "postgresql://hermes@localhost:5432/housing_tracker"

# CLI: python batch_geocode_poi.py [--poi-only]
# --poi-only: skip geocoding, only fill missing POI data
