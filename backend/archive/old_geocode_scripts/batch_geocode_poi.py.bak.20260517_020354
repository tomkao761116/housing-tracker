# Step 3: 批次 POI 查詢（差異更新）
# ============================================
print("=" * 60)
print("Step 3: 批次 POI 查詢（差異更新）")
print("=" * 60)

def fetch_poi(lat, lon, query):
    """使用 Overpass API 查詢周邊設施"""
    overpass_query = f"""
        [out:json][timeout:10];
        node["{query.split('=')[0]}="{query.split('=')[1]}""](around:500,{lat},{lon});
        out center limit 10;
    """
    url = "https://overpass-api.de/api/interpreter"
    data = urllib.parse.urlencode({"data": overpass_query}).encode()
    req = urllib.request.Request(url, data=data, headers={"User-Agent": "HousingTracker/1.0"})

    for attempt in range(3):
        try:
            with urllib.request.urlopen(req, timeout=15) as resp:
                result = json.loads(resp.read().decode("utf-8"))
                elements = result.get("elements", [])
                pois = []
                for elem in elements:
                    name = elem.get("tags", {}).get("name", "未知")
                    elat = elem.get("lat", lat)
                    elon = elem.get("lon", lon)
                    dist = int(haversine(lat, lon, elat, elon))
                    pois.append({"name": name, "distance": dist, "lat": elat, "lon": elon})
                return sorted(pois, key=lambda x: x["distance"])[:5]
        except Exception as e:
            print(f"  ⚠ POI 查詢嘗試 {attempt+1}/3 失敗: {e}")
            time.sleep(2)
    return []

# 取得有座標但缺少 POI 的紀錄
cur.execute("""
    SELECT t.id, t.lat, t.lon 
    FROM trades t
    WHERE t.lat IS NOT NULL AND t.lon IS NOT NULL
    AND NOT EXISTS (
        SELECT 1 FROM trade_amenities a WHERE a.trade_id = t.id
    )
""")
needs_poi_trades = cur.fetchall()
print(f"需查詢 POI: {len(needs_poi_trades)} 筆\n")

poi_success = 0
poi_failed = 0

for i, (tid, lat, lon) in enumerate(needs_poi_trades):
    print(f"[{i+1}/{len(needs_poi_trades)}] Trade #{tid} ({lat:.4f}, {lon:.4f})", end=" → ")

    total_pois = 0
    for cat, info in CATEGORIES.items():
        pois = fetch_poi(lat, lon, info["query"])
        for poi in pois:
            try:
                cur.execute(
                    "INSERT INTO trade_amenities (trade_id, category, amenity_name, distance, lat, lon) VALUES (%s, %s, %s, %s, %s, %s) ON CONFLICT DO NOTHING",
                    (tid, cat, poi["name"], poi["distance"], poi["lat"], poi["lon"])
                )
                total_pois += 1
            except Exception as e:
                print(f"  ⚠ 插入失敗: {e}")
        time.sleep(0.5)  # Overpass rate limit

    if total_pois > 0:
        poi_success += 1
        print(f"✓ {total_pois} 個設施")
    else:
        poi_failed += 1
        print("✗ 無資料")

    time.sleep(1.0)  # General rate limit

print(f"\nPOI 查詢完成: 成功 {poi_success} 筆, 失敗 {poi_failed} 筆\n")


